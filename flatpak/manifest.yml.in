# Flatpak manifest – generated from brand.json by npm run sync-brand
# Builds from the .deb package produced by `npm run tauri build -- --bundles deb`
#
# Prerequisites:
#   flatpak install flathub org.gnome.Platform//46 org.gnome.Sdk//46
#
# Build locally (after building .deb):
#   npm run prepare-flatpak-deb
#   flatpak-builder --repo=repo --force-clean build-dir flatpak/manifest.yml
#
# Run:
#   flatpak run {{APP_ID}}

app-id: {{APP_ID}}
runtime: org.gnome.Platform
runtime-version: "46"
sdk: org.gnome.Sdk
base: app
base-version: "46"
command: {{APP_SLUG}}

finish-args:
  - --socket=wayland
  - --socket=fallback-x11
  - --device=dri
  - --share=ipc
  - --share=network
  - --filesystem=xdg-config
  - --filesystem=xdg-data
  - --filesystem=home

modules:
  - name: {{APP_SLUG}}
    buildsystem: simple
    sources:
      - type: file
        path: {{APP_SLUG}}.deb
        dest-filename: {{APP_SLUG}}.deb
      - type: file
        path: metainfo.xml
    build-commands:
      - ar -x {{APP_SLUG}}.deb
      - tar -xf data.tar.*
      - install -Dm755 usr/bin/{{APP_SLUG}} -t /app/bin/
      - install -Dm644 metainfo.xml /app/share/metainfo/{{APP_ID}}.metainfo.xml
      - |
        for desktop in usr/share/applications/*.desktop; do
          [ -f "$desktop" ] && install -Dm644 "$desktop" /app/share/applications/{{APP_ID}}.desktop
        done
      - |
        for icon in usr/share/icons/hicolor/*/apps/*.png; do
          if [ -f "$icon" ]; then
            size=$(basename $(dirname $(dirname $icon)))
            name=$(basename $icon)
            install -Dm644 "$icon" "/app/share/icons/hicolor/$size/apps/$name"
          fi
        done
