{
  "name": "announcemint",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync-version": "node scripts/sync-version.js",
    "sync-brand": "node scripts/sync-brand.js",
    "dev": "vite",
    "build": "npm run sync-version && npm run sync-brand && vue-tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,vue,css}\"",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@fontsource/red-hat-display": "^5.1.0",
    "@fontsource/red-hat-mono": "^5.1.0",
    "@fontsource/red-hat-text": "^5.1.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.5.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "~5.6.0",
    "vite": "^5.0.0",
    "vue-tsc": "^2.0.0"
  }
}
